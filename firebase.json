{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
        {
        "source": "/api/**",
        "function": "api"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs18"
  },
  "emulators": {
    "functions": {
      "host": "127.0.0.1",
      "port": 5105
    },
    "hosting": {
      "host": "127.0.0.1",
      "port": 5106
    },
    "ui": {
      "host": "127.0.0.1",
      "port": 5107
    },
    "logging": {
      "host": "127.0.0.1",
      "port": 5108
    },
    "hub": {
      "host": "127.0.0.1",
      "port": 5109
    }
  }
}
